# Capacity Planning Dashboard - Environment Configuration Template
# ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env or .env.local to source control.
# Run scripts/New-EntraApp.ps1 to generate the ENTRA_* values.

# ── Entra ID Authentication ───────────────────────────────────────
# Set AUTH_ENABLED=true to enforce login. Leave false for local dev without credentials.
AUTH_ENABLED=false

# From the output of scripts/New-EntraApp.ps1:
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=
ENTRA_CLIENT_SECRET=

# Object ID of the Entra security group whose members get Admin access.
# Leave empty to disable admin gating (all authenticated users are admin).
ADMIN_GROUP_ID=

# Optional: Object ID of a group to track for general user access (informational, not enforced).
# USER_GROUP_ID=

# Redirect URI registered on the app. Default: http://localhost:3000/auth/callback
# For Azure App Service set this to: https://<your-app>.azurewebsites.net/auth/callback
AUTH_REDIRECT_URI=http://localhost:3000/auth/callback

## Random secret for express-session cookie signing. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In production this value is read from Azure Key Vault (secret: capdash-session-secret)
# and injected by App Service via a Key Vault reference — do NOT set it here for Azure deployments.
SESSION_SECRET=

# ── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Azure SQL ────────────────────────────────────────────────────
SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=your-database-name
SQL_AUTH_MODE=msi
# SQL_USER=        # Only needed for local dev with SQL auth
# SQL_PASSWORD=    # Only needed for local dev with SQL auth

# ── Ingestion ────────────────────────────────────────────────────
INGEST_API_KEY=
# In production this value is read from Azure Key Vault (secret: capdash-ingest-api-key)
# and injected by App Service via a Key Vault reference — do NOT set it here for Azure deployments.
INGEST_REGION_PRESET=USMajor
# INGEST_QUOTA_FAMILY_FILTERS=   # Leave empty to ingest all VM families
INGEST_ON_STARTUP=false
INGEST_INTERVAL_MINUTES=0
INGEST_SUBSCRIPTION_HASH_SALT=
# INGEST_SUBSCRIPTION_IDS=       # Optional comma-separated list; auto-discovers if omitted
INGEST_AI_ENABLED=false
INGEST_AI_PROVIDER_QUOTA_ENABLED=false
INGEST_AI_MODEL_CATALOG=true
# AI model catalog cadence is DB-backed via schedule.aiModelCatalog.intervalMinutes (default 1440 minutes)
# Keep provider-aware AI quota default-off until rollout validation is complete.
# Legacy aliases still work for rollback-safe deployments: INGEST_OPENAI_ENABLED / INGEST_OPENAI_MODEL_CATALOG / INGEST_OPENAI_MODEL_CATALOG_INTERVAL_MINUTES

# ── Quota Discovery ──────────────────────────────────────────────
QUOTA_MANAGEMENT_GROUP_ID=

# ── Capacity Worker (Azure Functions PowerShell host) ────────────
CAPACITY_WORKER_BASE_URL=
CAPACITY_WORKER_SHARED_SECRET=
CAPACITY_WORKER_TIMEOUT_MS=60000
CAPACITY_WORKER_DISABLE_LOCAL_FALLBACK=false

# ── Live Placement Refresh Scheduler ──────────────────────────────
LIVE_PLACEMENT_REFRESH_ON_STARTUP=false
LIVE_PLACEMENT_REFRESH_INTERVAL_MINUTES=0
LIVE_PLACEMENT_REFRESH_REGION_PRESET=USMajor
LIVE_PLACEMENT_REFRESH_DESIRED_COUNT=1
# LIVE_PLACEMENT_REFRESH_SUBSCRIPTION_IDS=    # Optional comma-separated list; falls back to INGEST_SUBSCRIPTION_IDS when omitted
# LIVE_PLACEMENT_REFRESH_REGION=all
# LIVE_PLACEMENT_REFRESH_FAMILY=all
# LIVE_PLACEMENT_REFRESH_AVAILABILITY=all
# LIVE_PLACEMENT_REFRESH_EXTRA_SKUS=          # Optional comma-separated extra SKUs to include in scheduled refreshes

# ── Azure Identity ───────────────────────────────────────────────
# AZURE_CLIENT_ID=     # Optional: managed identity client ID for local dev with DefaultAzureCredential
