{
  "type": "excalidraw",
  "version": 2,
  "source": "claude-basecoat-portal",
  "elements": [
    {
      "type": "rectangle",
      "x": 20,
      "y": 20,
      "width": 400,
      "height": 600,
      "strokeColor": "#1864ab",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": {
        "type": 3
      },
      "id": "login_container"
    },
    {
      "type": "text",
      "x": 40,
      "y": 50,
      "width": 360,
      "height": 60,
      "text": "Basecoat Portal",
      "fontSize": 32,
      "fontFamily": 2,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "top",
      "id": "login_title"
    },
    {
      "type": "text",
      "x": 40,
      "y": 120,
      "width": 360,
      "height": 30,
      "text": "Governance & Compliance Platform",
      "fontSize": 14,
      "fontFamily": 2,
      "strokeColor": "#666666",
      "textAlign": "center",
      "verticalAlign": "top",
      "id": "login_subtitle"
    },
    {
      "type": "text",
      "x": 40,
      "y": 170,
      "width": 360,
      "height": 25,
      "text": "Email Address",
      "fontSize": 14,
      "fontFamily": 2,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top",
      "id": "email_label"
    },
    {
      "type": "rectangle",
      "x": 40,
      "y": 200,
      "width": 360,
      "height": 40,
      "strokeColor": "#ebebeb",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roundness": {
        "type": 2
      },
      "id": "email_input"
    },
    {
      "type": "text",
      "x": 50,
      "y": 210,
      "width": 200,
      "height": 20,
      "text": "you@company.com",
      "fontSize": 14,
      "fontFamily": 2,
      "strokeColor": "#999999",
      "textAlign": "left",
      "verticalAlign": "middle",
      "id": "email_placeholder"
    },
    {
      "type": "text",
      "x": 40,
      "y": 260,
      "width": 360,
      "height": 25,
      "text": "Password",
      "fontSize": 14,
      "fontFamily": 2,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top",
      "id": "password_label"
    },
    {
      "type": "rectangle",
      "x": 40,
      "y": 290,
      "width": 360,
      "height": 40,
      "strokeColor": "#ebebeb",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roundness": {
        "type": 2
      },
      "id": "password_input"
    },
    {
      "type": "text",
      "x": 50,
      "y": 300,
      "width": 200,
      "height": 20,
      "text": "••••••••••",
      "fontSize": 14,
      "fontFamily": 2,
      "strokeColor": "#999999",
      "textAlign": "left",
      "verticalAlign": "middle",
      "id": "password_placeholder"
    },
    {
      "type": "rectangle",
      "x": 40,
      "y": 350,
      "width": 360,
      "height": 45,
      "strokeColor": "#0078d4",
      "backgroundColor": "#0078d4",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roundness": {
        "type": 2
      },
      "id": "login_button"
    },
    {
      "type": "text",
      "x": 50,
      "y": 360,
      "width": 340,
      "height": 25,
      "text": "Sign In",
      "fontSize": 16,
      "fontFamily": 2,
      "strokeColor": "#ffffff",
      "textAlign": "center",
      "verticalAlign": "middle",
      "id": "login_button_text"
    },
    {
      "type": "text",
      "x": 40,
      "y": 410,
      "width": 360,
      "height": 20,
      "text": "Forgot password? Reset here",
      "fontSize": 12,
      "fontFamily": 2,
      "strokeColor": "#0078d4",
      "textAlign": "center",
      "verticalAlign": "top",
      "id": "forgot_password_link"
    },
    {
      "type": "line",
      "x": 40,
      "y": 450,
      "width": 360,
      "height": 0,
      "strokeColor": "#ebebeb",
      "strokeWidth": 1,
      "id": "divider"
    },
    {
      "type": "rectangle",
      "x": 40,
      "y": 470,
      "width": 360,
      "height": 45,
      "strokeColor": "#1a1a1a",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roundness": {
        "type": 2
      },
      "id": "github_button"
    },
    {
      "type": "text",
      "x": 50,
      "y": 480,
      "width": 340,
      "height": 25,
      "text": "Sign in with GitHub",
      "fontSize": 14,
      "fontFamily": 2,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "id": "github_button_text"
    },
    {
      "type": "text",
      "x": 40,
      "y": 540,
      "width": 360,
      "height": 30,
      "text": "By signing in, you agree to our Terms of Service & Privacy Policy",
      "fontSize": 11,
      "fontFamily": 2,
      "strokeColor": "#999999",
      "textAlign": "center",
      "verticalAlign": "top",
      "id": "terms_text"
    }
  ],
  "appState": {
    "viewBackgroundColor": "#f5f5f5"
  }
}
