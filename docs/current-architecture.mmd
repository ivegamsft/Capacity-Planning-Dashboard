flowchart LR
    classDef group fill:#FFF7CC,stroke:#C9A227,stroke-width:1.5px,color:#332B00;
    classDef azure fill:#EAF4FF,stroke:#2B6CB0,stroke-width:1.5px,color:#0F2A43;
    classDef app fill:#E8FFF4,stroke:#1F7A4D,stroke-width:1.5px,color:#103222;
    classDef data fill:#F3ECFF,stroke:#6B46C1,stroke-width:1.5px,color:#2D1B69;
    classDef ops fill:#FFF0F0,stroke:#C53030,stroke-width:1.5px,color:#4A1111;
    classDef scope fill:#EEF8FF,stroke:#2563EB,stroke-width:1.5px,color:#102A43;

    User[Platform and Capacity Team]
    Browser[Browser UI\nCapacity Explorer + Admin controls\nQuota Workbench + feature-gated AI views]

    subgraph Experience[Experience Layer]
        direction TB
        WebApp[Azure App Service\nStatic UI + Express API\nSystem-assigned managed identity]
        Api[Node / Express endpoints\nhealthz\napi/capacity\napi/quota/* + api/ai/*\nApp Service flags gate AI ingest]
        Worker[Azure Function App worker\nPowerShell 7.4\nSystem-assigned managed identity]
    end

    subgraph Data[Data Platform]
        direction TB
        Sql[(Azure SQL Database\nCapacitySnapshot + AIModelAvailability\nCapacityLatest + AIModelAvailabilityLatest\nDashboardSetting AI cadence defaults)]
        Seed[Seed / schema scripts\nEntra-auth sqlcmd]
    end

    subgraph Access[RBAC Scope Hierarchy]
        direction TB
        Mg[Management Groups\nPreferred RBAC scope]
        Subs[Descendant subscriptions\nFallback explicit subscription lists]
    end

    subgraph Security[Security and Observability]
        direction TB
        Entra[Microsoft Entra admin\nAAD-only SQL authentication]
        Kv[Azure Key Vault\nRBAC enabled]
        Appi[Application Insights]
        Log[Log Analytics Workspace]
    end

    subgraph Delivery[Deployment Flow]
        direction TB
        Local[Local repo + scripts\nBicep or Terraform\nPowerShell + zip deploy]
        Infra[Infra deployment\nApp Service Plans\nWeb App + Worker\nSQL Server / DB or reuse\nKey Vault or reuse\nWorker storage or reuse\nInsights]
    end

    User --> Browser --> WebApp --> Api
    Api --> Worker
    Api -->|Managed identity auth| Sql
    Seed --> Sql
    Entra --> Sql
    WebApp -->|Key Vault Secrets User role| Kv
    Worker -->|Key Vault Secrets User + Storage RBAC| Kv
    WebApp --> Appi --> Log
    Worker --> Appi
    WebApp -->|Reader + GroupQuota Request Operator| Mg
    Worker -->|Compute Recommendations Role\nCost Management Reader\nBilling Reader| Mg
    Mg --> Subs
    Local --> Infra --> WebApp
    Local --> Infra --> Worker
    Local --> Seed

    class Experience,Data,Access,Security,Delivery group;
    class WebApp,Api,Worker app;
    class Sql,Seed data;
    class Entra,Kv,Appi,Log azure;
    class Local,Infra ops;
    class Mg,Subs scope;
